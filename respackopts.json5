{
    id: "deepOriginsOverlays",
    version: 9,
    capabilities: ["FileFilter", "DirFilter"],
    conf: {
        dirtPathAndFarmlandOverlays: true,
        allowBlockOverlaysOnThemselves: false,
        connectedSandstone: false,
        mossAndSnowOverhangs: {
            mossCarpetOverhangs: true,
            snowLayerOverhangs: true
        }
    }
}